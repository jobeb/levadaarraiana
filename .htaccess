RewriteEngine On

<IfModule mod_headers.c>
    # Allow microphone and camera for recording features
    Header set Permissions-Policy "microphone=(self), camera=(self)"

    # No cache for dev (JS, CSS, HTML)
    <FilesMatch "\.(js|css|html)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# Pass Authorization header to PHP
RewriteCond %{HTTP:Authorization} .+
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# API: redirect all /api/* requests to api/index.php
RewriteCond %{REQUEST_URI} ^/Levadaarraiana/api/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/(.*)$ api/index.php [QSA,L]

# Serve static files normally
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Uploads: allow direct access
RewriteCond %{REQUEST_URI} ^/Levadaarraiana/uploads/
RewriteRule ^ - [L]
